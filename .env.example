# =============================================================
# БД по умолчанию (grom-tk).
# Используется при каждом старте приложения — выбор БД на странице
# "Настройки" не сохраняется между перезапусками.
# =============================================================
DB_HOST=
DB_PORT=          # 6432 = pgbouncer (пул соединений), 5432 = прямой postgres
DB_USER=
DB_PASSWORD=
DB_NAME=

# =============================================================
# Альтернативная БД (grom-prod).
# Подключается вручную: Настройки -> Подключение к базе данных.
# =============================================================
DB_HOST_PROD=
DB_PORT_PROD=
DB_USER_PROD=
DB_PASSWORD_PROD=
DB_NAME_PROD=

# =============================================================
# Веб-сервер и сессии
# =============================================================
SERVER_PORT=8011

# Секрет для подписи cookie-сессии и CSRF-токена (см. app.py).
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# Уровень логирования (DEBUG, INFO, WARNING, ERROR). По умолчанию INFO.
LOG_LEVEL=INFO
